# CompX Worker — environment variables
# Copy this to .env and fill in your values

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://ulwwdxduhomslladdgcj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Redis (BullMQ) ────────────────────────────────────────────
# Local:   redis://localhost:6379
# Upstash: rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── Worker config ─────────────────────────────────────────────
WORKER_CONCURRENCY=3       # parallel jobs
NODE_ENV=production

# ── SaaS API base (for job callback) ─────────────────────────
NEXT_PUBLIC_APP_URL=https://comp-x.vercel.app
