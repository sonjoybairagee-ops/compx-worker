# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Redis (Upstash বা self-hosted) ────────────────────────────────────────────
# Self-hosted:
REDIS_URL=redis://:password@localhost:6379
# Upstash (TLS):
# REDIS_URL=rediss://default:token@your-endpoint.upstash.io:6379

# ── Worker Config ─────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=3
NODE_ENV=development

# ── Email Verification ────────────────────────────────────────────────────────
ZEROBOUNCE_API_KEY=your-zerobounce-key

# ── Internal IP whitelist (auth.ts এর জন্য) ──────────────────────────────────
INTERNAL_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# -- SerpApi (Backup / Extra Sources) ------------------------------------------
SERPAPI_API_KEY=your-serpapi-key
